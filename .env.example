# ── SARA — Environment Variables Template ──────────────────────────────────
# Copy this file to .env and fill in your actual API keys.
# Never commit your real .env file — it is in .gitignore.

# ── Groq (primary LLM — free tier available) ─────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Google Gemini (fallback LLM) ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── ElevenLabs (optional — premium TTS voice) ────────────────────────────────
# Get your key at: https://elevenlabs.io/app/settings/api-keys
# If not set, SARA uses edge-tts (free, Microsoft Azure voices) automatically.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# ── OpenRouter (optional — extra model access) ────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_KEY_1=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=cognitivecomputations/dolphin-mistral-24b-venice-edition:free
